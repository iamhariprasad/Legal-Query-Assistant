APP_NAME="AI-Powered Legal Query Assistant"
ENVIRONMENT=development
SECRET_KEY=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+asyncpg://legal:legal@postgres:5432/legal_assistant
REDIS_URL=redis://redis:6379/0
INDIAN_KANOON_BASE_URL=https://api.indiankanoon.org
INDIAN_KANOON_API_TOKEN=replace-with-token
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_PERSIST_DIR=/data/chroma
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
MIN_CONFIDENCE=0.62
MIN_CITATIONS=1
MAX_CONTEXT_CHUNKS=6

